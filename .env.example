# ===========================================
# Supabase
# ===========================================
# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# service_role キー（サーバー側のみで使用、絶対にクライアントに渡さない）
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Stripe（フェーズ3で使用、今は空でOK）
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# サイト URL（本番デプロイ後に Vercel のドメインに変更）
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
